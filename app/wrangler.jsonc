{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "delivery-ledger",
  "account_id": "4b7be23dfd1e141f49ea539451bc8233",
  "main": "worker.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "delivery-ledger-db",
      "database_id": "160a9092-ed2f-4a64-a6eb-a0445242b171",
      "migrations_dir": "drizzle/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "RECEIPTS",
      "bucket_name": "delivery-ledger-receipts"
    }
  ],
  "triggers": {
    "crons": ["0 15 1 * *", "0 15 5 1 *"]
  },
  "vars": {
    "BETTER_AUTH_URL": "https://delivery-ledger.shake1574.workers.dev",
    "R2_BUCKET_NAME": "delivery-ledger-receipts",
    "UPLOAD_MODE": "worker",
    "GEMINI_OCR_MODEL": "gemini-3.1-flash-lite"
  },
  "env": {
    "dev": {
      "name": "delivery-ledger-dev",
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "delivery-ledger-db",
          "database_id": "00000000-0000-0000-0000-000000000000",
          "migrations_dir": "drizzle/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "RECEIPTS",
          "bucket_name": "delivery-ledger-receipts-dev"
        }
      ],
      "vars": {
        "BETTER_AUTH_URL": "http://localhost:8787",
        "BETTER_AUTH_SECRET": "local-development-secret-change-before-production",
        "R2_BUCKET_NAME": "delivery-ledger-receipts-dev",
        "UPLOAD_MODE": "local",
        "GEMINI_OCR_MODEL": "gemini-3.1-flash-lite"
      }
    }
  }
}
